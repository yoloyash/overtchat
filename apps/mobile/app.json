{
  "expo": {
    "name": "overtchat",
    "slug": "overtchat",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "overtchat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.overtchat.mobile"
    },
    "android": {
      "package": "com.overtchat.mobile",
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow overtchat to access your photos so you can attach them to chats.",
          "cameraPermission": "Allow overtchat to use your camera so you can attach photos to chats."
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
