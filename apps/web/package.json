{
  "name": "@overtchat/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "mkdir -p data && next dev -p 4717",
    "build": "next build",
    "start": "mkdir -p data && next start -p 4717",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "rm -f data/test.db* && playwright test",
    "test:e2e:ui": "rm -f data/test.db* && playwright test --ui",
    "auth:generate": "better-auth generate --config lib/auth/server.ts --output lib/db/schema.ts --y",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "mkdir -p data && drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@ai-sdk/react": "^3.0.178",
    "@base-ui/react": "^1.4.1",
    "@better-auth/expo": "^1.6.11",
    "@overtchat/shared": "*",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "ai": "^6.0.176",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clipboard-polyfill": "^4.1.1",
    "clsx": "^2.1.1",
    "defuddle": "^0.18.1",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "ipaddr.js": "^2.4.0",
    "katex": "^0.16.45",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "media-chrome": "^4.19.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-simple-code-editor": "^0.14.1",
    "redis": "^5.12.1",
    "remark": "^15.0.1",
    "remark-breaks": "^4.0.0",
    "resumable-stream": "^2.2.12",
    "server-only": "^0.0.1",
    "shadcn": "^4.7.0",
    "streamdown": "^2.5.0",
    "strip-markdown": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.6.2",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
