# Base URL of the bundled SearXNG instance (from compose.yml).
# Set this if searxng lives somewhere other than the default.
SEARXNG_URL=http://localhost:8088

# Host port exposed by the searxng container. Change if 8088 is taken.
SEARXNG_PORT=8088

# Secret for SearXNG's internal signing. Any random string; regenerate for prod.
SEARXNG_SECRET=change-me-in-production
