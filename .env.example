# Copy to .env and fill in values. Used by `docker compose up` and `npm run dev`.

# Better Auth — required. Populate via:
#   echo "BETTER_AUTH_SECRET=$(openssl rand -hex 32)" >> .env

# URL the browser will hit (include scheme). Used for cookies + callback URLs.
# For LAN access from other devices, set to your host's LAN IP,
# e.g. http://192.168.1.50:4718. Must match what the browser sees.
BETTER_AUTH_URL=http://localhost:4718

# Host port for the app container. The container itself always listens on 4717.
# Default 4718 so it doesn't collide with `npm run dev` (which uses 4717).
APP_PORT=4718

# SearXNG signing secret. Required. Populate via:
#   echo "SEARXNG_SECRET=$(openssl rand -hex 32)" >> .env
SEARXNG_SECRET=

# Base URL for searxng when running `npm run dev` on the host.
# In docker compose, the app talks to searxng via http://searxng:8080 automatically.
SEARXNG_URL=http://localhost:8088

# Base URL for the speech-to-text sidecar when running `npm run dev` on the host.
# In docker compose, the app talks to it via http://stt:5092 automatically.
# STT is opt-in: only enabled if you bring it up with `--profile stt` (CPU)
# or `--profile stt-gpu` (NVIDIA GPU).
STT_URL=http://localhost:5092

# Redis used as the buffer for resumable assistant streams (so reload mid-reply
# doesn't drop your tokens). Required by the app. In docker compose this is
# overridden to redis://redis:6379 automatically. For host `npm run dev`,
# bring up the same Redis container with `-f compose.yml -f compose.dev.yml up redis`.
REDIS_URL=redis://localhost:6379

# Host interface to bind published sidecar ports to (searxng, kokoro, stt, redis).
# Defaults to 127.0.0.1 so the stack is reachable only from this host.
# Set to 0.0.0.0 to expose to your LAN (e.g. so other machines or another
# overtchat stack on the same host can reuse one shared sidecar set). Your
# router still won't forward these unless you explicitly configure it to.
# BIND_ADDR=0.0.0.0

# --- Sidecar host ports ---
# Used by both compose.yml (searxng, kokoro) and compose.dev.yml (stt, redis).
SEARXNG_PORT=8088
KOKORO_PORT=8880
STT_PORT=5092
REDIS_PORT=6379

# SQLite file location for local `npm run dev`. Ignored in docker (path is baked in).
# DATABASE_URL=./data/chat.db

# Extra origins to trust for CORS + Better Auth's origin check (comma-separated).
# Use this in this file (.env) only for prod URLs that aren't BETTER_AUTH_URL.
# For dev (LAN IPs, exp://, localhost), put values in apps/web/.env.local instead —
# that file is gitignored and only loaded by `next dev`.
# Example: EXTRA_TRUSTED_ORIGINS=http://192.168.1.50:4717,exp://192.168.1.50:8081
EXTRA_TRUSTED_ORIGINS=
